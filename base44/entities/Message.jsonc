{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "ID of the conversation this message belongs to"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant"
      ],
      "description": "Who sent the message"
    },
    "content": {
      "type": "string",
      "description": "The message content"
    },
    "token_count": {
      "type": "number",
      "description": "Number of tokens used in this message"
    },
    "char_count": {
      "type": "number",
      "description": "Number of characters in the message content"
    },
    "word_count": {
      "type": "number",
      "description": "Number of words in the message content"
    },
    "file_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Attached file URLs"
    },
    "generated_files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "description": "Files generated by CAOS"
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "arguments_string": {
            "type": "string"
          },
          "results": {
            "type": "string"
          }
        }
      },
      "description": "Tool calls made during generation"
    },
    "response_time_ms": {
      "type": "number",
      "description": "Time taken to generate response in milliseconds"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the message was sent"
    },
    "reactions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "emoji": {
            "type": "string"
          },
          "selected_text": {
            "type": "string"
          }
        }
      },
      "description": "Emoji reactions to selected text"
    },
    "replies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "selected_text": {
            "type": "string"
          },
          "user_reply": {
            "type": "string"
          },
          "ai_response": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      },
      "description": "Thread replies to selected text with AI responses"
    },
    "metadata_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Auto-extracted marker tags for same-thread retrieval (MBCR v1)"
    },
    "inference_provider": {
      "type": "string",
      "enum": [
        "openai",
        "gemini",
        "grok",
        "local"
      ],
      "description": "Which inference provider generated this assistant message"
    }
  },
  "required": [
    "conversation_id",
    "role",
    "content"
  ]
}